# Mistral
MISTRAL_API_KEY=your_key
MISTRAL_BASE_URL=                          # Optional: Azure AI endpoint override

# JWT Auth
JWT_SECRET=your_secret                     # For HS256
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----   # For RS256
JWT_ALGORITHM=HS256
JWT_ISSUER=                                # Optional: validate iss claim
JWT_AUDIENCE=                              # Optional: validate aud claim

# Limits
MAX_REQUEST_SIZE_MB=50
REQUEST_TIMEOUT_MS=120000
MAX_REGEX_EXECUTION_MS=100                 # Per-regex safety timeout
MAX_RULES_PER_CATEGORY=100                 # Cap on number of rules caller can send
